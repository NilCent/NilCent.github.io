&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="nl">jobs&lt;/span>&lt;span class="p">:&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="nl">deploy&lt;/span>&lt;span class="p">:&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="nv">runs&lt;/span>&lt;span class="o">-&lt;/span>&lt;span class="nv">on&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="nv">ubuntu&lt;/span>&lt;span class="o">-&lt;/span>&lt;span class="mf">22.04&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="nl">steps&lt;/span>&lt;span class="p">:&lt;/span>
