&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="nv">uses&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="nv">actions&lt;/span>&lt;span class="o">/&lt;/span>&lt;span class="nv">checkout&lt;/span>&lt;span class="o">@&lt;/span>&lt;span class="nv">v2&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="o">-&lt;/span> &lt;span class="nv">name&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="nc">Update&lt;/span> &lt;span class="nv">theme&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="o">#&lt;/span> &lt;span class="p">(&lt;/span>&lt;span class="nc">Optional&lt;/span>&lt;span class="p">)&lt;/span>&lt;span class="nc">If&lt;/span> &lt;span class="nv">you&lt;/span> &lt;span class="nv">have&lt;/span> &lt;span class="nv">the&lt;/span> &lt;span class="nv">theme&lt;/span> &lt;span class="nv">added&lt;/span> &lt;span class="k">as&lt;/span> &lt;span class="nv">submodule&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="nv">you&lt;/span> &lt;span class="nv">can&lt;/span> &lt;span class="nv">pull&lt;/span> &lt;span class="vm">it&lt;/span> &lt;span class="nv">and&lt;/span> &lt;span class="nv">use&lt;/span> &lt;span class="nv">the&lt;/span> &lt;span class="nv">most&lt;/span> &lt;span class="nv">updated&lt;/span> &lt;span class="nv">version&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="nv">run&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="nv">git&lt;/span> &lt;span class="nv">submodule&lt;/span> &lt;span class="nv">update&lt;/span> &lt;span class="o">--&lt;/span>&lt;span class="nv">init&lt;/span> &lt;span class="o">--&lt;/span>&lt;span class="nv">recursive&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="o">-&lt;/span> &lt;span class="nv">name&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="nc">Setup&lt;/span> &lt;span class="nv">hugo&lt;/span>
